# cape-installer 用户参数
# 复制此文件为 config.env 并按需修改。
# 仅暴露两个参数（决策见 docs/WHY.md ADR-Q4），其他全部硬编码。

# CAPE 客户机网段。libvirt default 网络 virbr0 会被设为此 IP。
# 默认 192.168.122.1/24（libvirt 出厂默认，与本机外部网段不冲突即可）。
SUBNET=192.168.122

# CAPE PostgreSQL 用户密码。仅本机内监听（127.0.0.1:5432）。
# 默认沿用 cape2.sh 上游默认。
DB_PASSWORD=SuperPuperSecret
