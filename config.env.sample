# cape-installer 用户参数
# 复制此文件为 config.env 并按需修改。
# 仅暴露两个参数（决策见 docs/WHY.md ADR-Q4），其他全部硬编码。

# CAPE 客户机网段。libvirt default 网络 virbr0 会被设为此 IP。
# 默认 192.168.122.1/24（libvirt 出厂默认，与本机外部网段不冲突即可）。
SUBNET=192.168.122

# CAPE PostgreSQL 用户密码。仅本机内监听（127.0.0.1:5432）。
# 默认沿用 cape2.sh 上游默认。
DB_PASSWORD=SuperPuperSecret

# === Phase C：分析客户机（make import-guest 用） ===
# 客户机 libvirt domain 名 + kvm.conf section 名（保持一致）。
GUEST_NAME=cuckoo1

# 客户机静态 IP，必须在 ${SUBNET}.0/24 内（默认网段 192.168.122）。
# 客户机内 c-guest-prep.ps1 也会写死同一个 IP（双保险）。
GUEST_IP=192.168.122.105

# 客户机 MAC。前缀 52:54:00 是 libvirt 官方保留段，后 3 字节自定。
# 用于 libvirt 的 DHCP reservation（MAC→IP 绑定）。
GUEST_MAC=52:54:00:CA:FE:01

# 客户机资源（可调）。
GUEST_RAM_MB=4096
GUEST_VCPUS=2

# 客户机 OS / 架构 / CAPE tags——CAPE Web UI Submit 页 Machine 下拉显示这些。
# Win10 LTSC x64 默认；Win7 客户机命令行覆盖：
#   sudo make import-guest GUEST_QCOW2=... GUEST_NAME=cuckoo2 GUEST_TAGS=win7,x64,cape ...
GUEST_PLATFORM=windows
GUEST_ARCH=x64
GUEST_TAGS=win10ltsc,x64,cape
